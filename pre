<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>畢業旅行前的校園懸疑事件</title>

<style>
body{
    font-family: Arial, sans-serif;
    background:#f4f6f8;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.container{
    background:white;
    width:700px;
    max-width:95%;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,0.1);
}

h1{
    text-align:center;
}

#story{
    font-size:20px;
    margin:20px 0;
    line-height:1.6;
}

button{
    display:block;
    width:100%;
    margin:10px 0;
    padding:12px;
    font-size:16px;
    cursor:pointer;
    border:none;
    border-radius:8px;
    background:#4a90e2;
    color:white;
}

button:hover{
    background:#357abd;
}

#restart{
    background:#28a745;
}
</style>
</head>
<body>

<div class="container">

<h1>🎓 畢業旅行前的校園懸疑事件</h1>

<div id="story"></div>

<div id="choices"></div>

</div>

<script>

const game = {

start:{
text:`下週就是畢業旅行。

班導突然發現旅行行程表和住宿名單不見了。

如果今天找不到，畢旅可能被延後。

你決定開始調查。`,
choices:[
["前往教室","classroom"],
["前往教師辦公室","office"],
["前往圖書館","library"]
]
},

classroom:{
text:`你詢問同學。

同學表示午休時曾有人幫老師送資料。`,
choices:[
["去教師辦公室","office"],
["去學生會辦公室","studentCouncil"]
]
},

office:{
text:`老師表示他把資料放在桌上後就去開會了。

另一位老師說看到有人拿著藍色資料夾離開。`,
choices:[
["查看監視器","camera"],
["前往圖書館","library"]
]
},

library:{
text:`圖書館管理員說下午有人影印過住宿名單。`,
choices:[
["前往影印室","copyRoom"],
["前往學生會辦公室","studentCouncil"]
]
},

camera:{
text:`監視器畫面顯示：

有人拿著藍色資料夾走進學生會辦公室。`,
choices:[
["前往學生會辦公室","studentCouncil"]
]
},

studentCouncil:{
text:`學生會長表示：

「我們收到資料後，以為是活動文件，所以轉交給活動組了。」`,
choices:[
["追查活動組","finalChoice"],
["直接指控學生會","badEnding"]
]
},

copyRoom:{
text:`工讀生表示：

「確實有人影印資料，但影印後又放回資料夾了。」`,
choices:[
["追查活動組","finalChoice"],
["認為是老師弄丟的","normalEnding"]
]
},

finalChoice:{
text:`目前線索顯示：

資料曾經經過學生會，最後被送往活動組。

你決定怎麼做？`,
choices:[
["追查活動組","goodEnding"],
["指控學生會","badEnding"],
["認為老師自己弄丟","normalEnding"]
]
},

goodEnding:{
text:`🏆 真結局

你找到活動組。

原來資料被夾進畢旅海報設計稿中。

因為資料夾顏色相同，所以大家一直沒發現。

全班順利參加畢業旅行！`,
choices:[]
},

normalEnding:{
text:`🙂 普通結局

老師最後重新整理文件。

成功找到遺失資料。

畢旅照常舉行，但不是你找到的。`,
choices:[]
},

badEnding:{
text:`😅 壞結局

你誤會了學生會。

後來證明他們只是按照流程轉交資料。

真正原因仍然沒有被你找出。`,
choices:[]
}

};

function showScene(scene){

const current = game[scene];

document.getElementById("story").innerText = current.text;

const choicesDiv = document.getElementById("choices");
choicesDiv.innerHTML = "";

current.choices.forEach(choice=>{

const btn = document.createElement("button");

btn.innerText = choice[0];

btn.onclick = ()=>showScene(choice[1]);

choicesDiv.appendChild(btn);

});

if(current.choices.length===0){

const restartBtn = document.createElement("button");

restartBtn.id = "restart";

restartBtn.innerText = "重新開始";

restartBtn.onclick = ()=>showScene("start");

choicesDiv.appendChild(restartBtn);

}

}

showScene("start");

</script>

</body>
</html>
